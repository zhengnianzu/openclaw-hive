# OpenClaw Hive Platform 配置
# 复制此文件为 .env 并修改

# ===== 路径配置 =====
# obsutil 可执行文件路径
OBSUTIL_PATH=/home/nianzuzheng/project/openclaw-hive/platform/obsutil/obsutil

# OBS 桶地址
OBS_BUCKET=obs://rl-agentdata

# config.yaml 模板路径（创建任务实例时以此为基础）
CONFIG_TEMPLATE=/home/nianzuzheng/project/openclaw-hive/platform/settings/config.yaml

# 模板配置文件目录（config.yaml, openclaw.json, user_proxy_model.json）
SETTINGS_DIR=/home/nianzuzheng/project/openclaw-hive/platform/settings

# openclaw-hive 项目根目录
HIVE_ROOT=/home/nianzuzheng/project/openclaw-hive

# ===== 安全配置 =====
# JWT 签名密钥（生产环境务必修改为随机字符串）
SECRET_KEY=change-me-to-a-random-string

# Token 有效期（分钟），默认 24 小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 数据库 =====
# SQLite 数据库路径
DB_PATH=/home/nianzuzheng/project/openclaw-hive/platform/platform.db

# ===== 初始管理员账号（首次启动自动创建） =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
