# OpenClaw Hive Platform 配置
# 复制此文件为 .env 并修改

# ===== 路径配置 =====
# obsutil 可执行文件路径（必须是绝对路径）
OBSUTIL_PATH=/home/nianzuzheng/project/openclaw-hive/platform/obsutil/obsutil

# OBS 桶地址
OBS_BUCKET=obs://rl-agentdata

# 以下路径留空则自动基于 HIVE_ROOT 推导，一般不需要改
# HIVE_ROOT=           # 默认自动检测（config.py 所在位置向上推导）
# CONFIG_TEMPLATE=     # 默认 {HIVE_ROOT}/platform/settings/config.yaml
# SETTINGS_DIR=        # 默认 {HIVE_ROOT}/platform/settings
# DB_PATH=             # 默认 {HIVE_ROOT}/platform/platform.db

# ===== 安全配置 =====
# JWT 签名密钥（生产环境务必修改为随机字符串）
SECRET_KEY=change-me-to-a-random-string

# Token 有效期（分钟），默认 24 小时
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===== 初始管理员账号（首次启动自动创建） =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
